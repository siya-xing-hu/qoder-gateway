# ==================================================================================================
# Qoder Gateway Configuration
# ==================================================================================================

# --- Server Settings ---
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# --- Authentication ---
# API key for accessing this gateway (clients must pass this in Authorization header)
QODER_PROXY_API_KEY=my-qoder-secret-password-123

# Personal Access Token for Qoder API
# Get your token from: https://qoder.com/account/integrations
# QODER_PERSONAL_ACCESS_TOKEN=your-token-here

# Path to Qoder CLI config file (alternative to env variable)
# Default: ~/.qoder.json
# QODER_CONFIG_FILE=

# --- Qoder API (for future HTTP API mode) ---
# QODER_API_BASE_URL=https://api.qoder.com
# QODER_API_VERSION=v1

# --- Timeout Settings ---
# QODER_FIRST_TOKEN_TIMEOUT=30
# QODER_STREAMING_READ_TIMEOUT=300
# QODER_FIRST_TOKEN_MAX_RETRIES=3

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_DIR=logs

# --- Workspace ---
# Working directory for qodercli (where generated code is stored)
# QODER_WORKSPACE=/home/qoder/repo

# --- Database (optional, for request log persistence) ---
# If not set, request logs are only printed to console.
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/qoder
